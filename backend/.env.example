# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (use USE_SQLITE=true for local dev without MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=op_character
DB_USER=opuser
DB_PASSWORD=oppassword
USE_SQLITE=true

# Redis (use USE_INMEMORY_CHANNEL=true without Redis)
REDIS_URL=redis://127.0.0.1:6379/0
USE_INMEMORY_CHANNEL=true

# Admin CMS (set a secret key to enable /admin UI on the frontend)
ADMIN_API_KEY=change-me-in-production

# Railway / production (optional locally)
# DJANGO_ALLOWED_HOSTS=*
# DATA_DIR=/app/data
# DATABASE_PATH=/app/data/db.sqlite3
# RAILWAY_ENVIRONMENT=true
